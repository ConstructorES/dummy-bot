{
    "name": "dummy-bot",
    "module": "index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "bun run ./src/index.ts",
        "build": "NODE_ENV=production bun build --compile --no-compile-autoload-bunfig --minify --target=bun-linux-x64-baseline --bytecode ./src/index.ts --outfile=./build/dummy",
        "deploy": "bun run build && bun run ./deploy.ts"
    },
    "devDependencies": {
        "@types/bun": "latest"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "bufferutil": "^4.1.0",
        "discord.js": "^14.26.4",
        "zlib-sync": "^0.1.10"
    }
}
